defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

account fastmail
host smtp.fastmail.com
port 587
from hskim@dilluti0n.com
user hskim@dilluti0n.com
passwordeval "pass show hskim/fastmail.com | awk '/^app-password-eps:/ {print $2}'"

account fastmail-gmail
host smtp.fastmail.com
port 587
from hskimse1@gmail.com
user hskim@dilluti0n.com
passwordeval "pass show hskim/fastmail.com | awk '/^app-password-eps:/ {print $2}'"

account default : fastmail
