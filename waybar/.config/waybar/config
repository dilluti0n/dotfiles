{
    "layer": "top",
    "position": "top",
    "modules-left": ["niri/workspaces", "mpris"],
    "modules-center": ["niri/window"], 
    "modules-right": [
        "pulseaudio",
        "custom/bzmenu",
        "network#wlan",
        "network#eth",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "custom/swayidle",
        "tray",
        "clock"
    ],

    "custom/swayidle": {
        "exec": "swayidle-toggle.sh status",
        "interval": "once",
        "signal": 8,
        "on-click": "swayidle-toggle.sh toggle",
        "return-type": "json",
        "tooltip": false
    },
    "sway/workspaces": {
        "format": "{name}"
    },
    "mpris": {
        "format": "MPRIS {player}",
        "format-paused": "MPRIS {player} (PAUSED)",
        "player-icons": {
            "default": ""
        },
        "status-icons": {
            "playing": "PLAY",
            "paused": "PAUSE",
            "stopped": "STOP"
        },
        "max-length": 25
    },
    "clock": {
        "format": "{:%Y-%m-%d | %H:%M}",
        "tooltip-format": "{:%Y-%m-%d | %H:%M}"
    },
    "cpu": {
        "format": "CPU {usage}%"
    },
    "memory": {
        "format": "MEM {percentage}%"
    },
    "temparature": {
        "format": "{temperatureC}",
        "interval": 10
    },
    "battery": {
        "bat": "BAT0",
        "interval": 5,
        "format": "BAT {capacity}%",
        "format-charging": "CHARGING {capacity}%",
        "format-plugged": "PLUGGED {capacity}%",
        "format-alt": "BAT {time}"
    },
    "network#wlan": {
        "interface": "wlan0",
        "format-wifi": "WIFI {essid}",
        "format-disconnected": "WIFI N/A",
        "on-click": "killall -q iwgtk || iwgtk"
    },
    "network#eth": {
        "interface": "enp1s0f0",
        "format-ethernet": "ETH {ifname}",
        "format-disconnected": ""
    },
    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTED",
        "on-click": "killall -q pavucontrol || pavucontrol"
    },
    "tray": {
        "icon-size": 15,
        "sapcing": 10
    },
    "custom/bzmenu": {
        "format": "BZMENU",
        "on-click": "bzmenu -l bemenu",
        "tooltip": false
    }
}
