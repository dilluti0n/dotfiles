{
    "layer": "top",
    "position": "top",
    "modules-left": ["niri/workspaces", "mpris"],
    "modules-center": ["niri/window"], 
    "modules-right": [
        "pulseaudio",
        "custom/bzmenu",
        "network#wlan",
        "network#eth",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "idle_inhibitor",
        "custom/swayidle",
        "tray",
        "clock"
    ],

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "Idle off",
            "deactivated": "Idle on"
        }
    },
    "sway/workspaces": {
        "format": "{name}"
    },
    "mpris": {
        "format": "Mpris {player}",
        "format-paused": "Mpris {player} (PAUSED)",
        "player-icons": {
            "default": ""
        },
        "status-icons": {
            "playing": "Playing",
            "paused": "Paused",
            "stopped": "Stopped"
        },
        "max-length": 25
    },
    "clock": {
        "format": "{:%Y-%m-%d | %H:%M}",
        "tooltip-format": "{:%Y-%m-%d | %H:%M}"
    },
    "cpu": {
        "format": "{usage}%"
    },
    "memory": {
        "format": "{percentage}%"
    },
    "temparature": {
        "format": "{temperatureC}",
        "interval": 10
    },
    "battery": {
        "bat": "BAT0",
        "interval": 5,
        "format": "{capacity}%",
        "format-charging": "C {capacity}%",
        "format-plugged": "P {capacity}%",
        "format-alt": "{time}"
    },
    "network#wlan": {
        "interface": "wlan0",
        "format-wifi": "Wifi {essid}",
        "format-disconnected": "Wifi N/A",
        "on-click": "killall -q iwgtk || iwgtk"
    },
    "network#eth": {
        "interface": "enp1s0f0",
        "format-ethernet": "Eth {ifname}",
        "format-disconnected": ""
    },
    "pulseaudio": {
        "format": "V {volume}%",
        "format-muted": "Muted",
        "on-click": "killall -q pavucontrol || pavucontrol"
    },
    "tray": {
        "icon-size": 15,
        "sapcing": 10
    },
    "custom/bzmenu": {
        "format": "Bluetooth",
        "on-click": "bzmenu -l bemenu",
        "tooltip": false
    }
}
